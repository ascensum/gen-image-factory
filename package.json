{
  "name": "gen-image-factory",
  "version": "1.3.0",
  "description": "AI-powered image generation application with Electron, React, and TypeScript",
  "main": "electron/main.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:dev:log": "./scripts/run-with-debug-log.sh electron-dev bash -c 'export NODE_ENV=development && exec electron .'",
    "electron:build": "npm run build && electron .",
    "migrate": "node scripts/run-migrations.js",
    "lint": "eslint . --ext js,jsx,ts,tsx",
    "lint:fix": "eslint . --ext js,jsx,ts,tsx --fix",
    "format": "prettier --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "tsc --noEmit -p tsconfig.typecheck.json && vitest run",
    "test:run:log": "./scripts/run-with-debug-log.sh test-run npm run test:run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:run && npm run test:e2e",
    "test:regression": "./scripts/run-regression-tests.sh",
    "test:regression:fast": "./scripts/run-regression-tests.sh --fast",
    "test:regression:e2e": "./scripts/run-regression-tests.sh --e2e",
    "test:regression:unit": "./scripts/run-regression-tests.sh --unit",
    "test:regression:integration": "./scripts/run-regression-tests.sh --integration",
    "prepare": "husky install",
    "test:job-management": "vitest run tests/unit/logic/jobManagement.logic.test.ts tests/integration/backend/ExportExcel.integration.test.ts",
    "test:job-management:watch": "vitest tests/unit/logic/jobManagement.logic.test.ts tests/integration/backend/ExportExcel.integration.test.ts",
    "test:retry": "vitest run tests/unit/services/RetryExecutor.test.ts tests/integration/backend/RetryFunctionality.integration.test.ts",
    "test:retry:watch": "vitest tests/unit/services/RetryExecutor.test.ts tests/integration/backend/RetryFunctionality.integration.test.ts",
    "test:security": "vitest run tests/unit/services/RetryExecutor.test.ts --reporter=verbose",
    "test:regression:retry": "npm run test:retry && npm run test:job-management",
    "test:labels": "vitest run tests/unit/ui/JobHistoryLabelFormatting.test.tsx",
    "test:labels:all": "vitest run tests/unit/ui/JobHistoryLabelFormatting.test.tsx tests/unit/ui/DashboardFiltersLabelFormatting.test.tsx tests/unit/ui/FailedImagesReviewFiltersLabelFormatting.test.tsx",
    "test:exports": "vitest run tests/integration/backend/ExportZip.integration.test.ts tests/integration/backend/ExportJobExcel.integration.test.ts tests/integration/backend/BulkExportJobs.integration.test.ts",
    "test:integration:db": "vitest run tests/integration/database/JobConfiguration.integration.test.ts",
    "test:critical": "vitest run tests/unit/services/JobEngine.test.ts tests/unit/services/JobService.test.ts tests/unit/services/ExportService.test.ts tests/unit/services/SecurityService.test.ts tests/unit/services/RetryQueueService.test.js tests/unit/services/RetryProcessorService.test.js tests/integration/api/ipc-preload.integration.test.ts",
    "validate:store-identity": "node scripts/validate-store-identity.js",
    "repo:scan": "node scripts/repo-scan.js",
    "repo:scan:staged": "node scripts/repo-scan.js --staged",
    "repo:clean": "node scripts/repo-clean.js",
    "guardrails:check": "npm run repo:scan && npm run test:exports && npm run test:retry && npm run test:labels && npm run test:security && npm run test:job-management",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "rebuild-icons": "node scripts/rebuild-icons.js",
    "preview-icons": "node scripts/preview-icons.js",
    "release-notes": "node scripts/extract-release-notes.js",
    "release-notes:latest": "node scripts/extract-release-notes.js latest"
  },
  "author": {
    "name": "Shiftline Tools",
    "email": "vjatseslav.jertsalov@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "archiver": "^5.3.1",
    "axios": "^1.15.0",
    "cheerio": "^1.0.0-rc.12",
    "color": "^5.0.3",
    "color-convert": "^3.1.3",
    "color-name": "^2.1.0",
    "crypto-js": "^4.2.0",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.0.3",
    "electron-updater": "^6.6.2",
    "exceljs": "^4.4.0",
    "form-data": "^4.0.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.536.0",
    "openai": "^4.52.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-window": "^2.2.6",
    "sharp": "^0.32.0",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1",
    "yargs": "^17.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@ffflorian/electron-icon-generator": "^1.12.1",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.9",
    "@types/react-devtools": "^3.6.2",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.9.14",
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "png2icons": "^2.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "terser": "^5.46.0",
    "typescript": "^5.9.2",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "tar": ">=7.5.10",
    "minimatch": ">=10.2.3",
    "lodash": ">=4.18.1",
    "@xmldom/xmldom": ">=0.8.12",
    "undici": ">=7.24.6",
    "picomatch": ">=2.3.2",
    "brace-expansion": ">=5.0.5",
    "flatted": ">=3.4.2",
    "path-to-regexp": ">=0.1.13",
    "serialize-javascript": ">=6.0.2",
    "svgo": ">=3.3.3",
    "@tootallnate/once": ">=3.0.1",
    "file-type": ">=21.3.1",
    "ajv": ">=6.14.0",
    "eslint": {
      "ajv": "^6.14.0"
    },
    "@eslint/eslintrc": {
      "ajv": "^6.14.0"
    }
  }
}
